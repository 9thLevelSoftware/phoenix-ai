{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "phoenix-ai-api",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-01",
  "ai_search": [
    {
      "binding": "KB",
      "instance_name": "phoenix-vitruvian-kb",
      "remote": true
    }
  ],
  "vars": {
    "CF_ACCOUNT_ID": "",
    "AI_GATEWAY_ID": "phoenix-ai",
    "MODEL_PROVIDER": "workersai",
    "WORKERS_AI_MODEL": "@cf/moonshotai/kimi-k2.6",
    "AZURE_RESOURCE_NAME": "",
    "AZURE_DEPLOYMENT_NAME": "",
    "AZURE_API_VERSION": "2023-05-15",
    "ALLOWED_ORIGIN": "*",
    "PHOENIX_DEBUG_ENABLED": "false",
    "LOCAL_LLM_URL": "",
    "LOCAL_LLM_MODEL": "qwen2.5-7b-coaching-v4-Q4_K_M",
    "LOCAL_LLM_API_KEY": ""
  }
}
