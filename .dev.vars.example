# Copy this file to .dev.vars for local Wrangler development.
# Keep real values out of git. The real .dev.vars file is ignored.

# Required for MODEL_PROVIDER=workersai.
CF_API_TOKEN=

# Required only when trusted debug responses are enabled.
PHOENIX_DEBUG_TOKEN=

# Required for MODEL_PROVIDER=local (e.g., llama.cpp server)
LOCAL_LLM_URL=http://localhost:8080/v1/chat/completions
LOCAL_LLM_MODEL=qwen2.5-7b-coaching-v4-Q4_K_M
LOCAL_LLM_API_KEY=
